{
  "name": "angular-liquid-glass-docs",
  "version": "0.1.0",
  "description": "Documentation app for the angular-liquid-glass component library.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:local": "npm run build:lib && ng serve --configuration local",
    "build": "ng build",
    "build:local": "npm run build:lib && ng build --configuration local",
    "build:pages": "ng build --configuration production --base-href=/angular-liquid-glass-docs/",
    "postbuild:pages": "cp dist/angular-liquid-glass-docs/browser/index.html dist/angular-liquid-glass-docs/browser/404.html",
    "build:lib": "cd ../../angular-liquid-glass && npm run build",
    "watch:lib": "cd ../../angular-liquid-glass && npm run watch",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false"
  },
  "private": true,
  "packageManager": "npm@11.6.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "angular-liquid-glass": "^0.1.0",
    "highlight.js": "^11.11.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
